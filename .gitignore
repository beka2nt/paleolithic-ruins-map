# .gitignore

# 字节码和缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
venv/
.venv/
env/
ENV/

# IDE 和编辑器配置
.idea/
.vscode/
*.swp
*.swo

# Django 临时文件和本地配置
*.sqlite3
*.log
db.sqlite3
.env
_env.bak

# 操作系统文件
.DS_Store
Thumbs.db

# `collectstatic` 输出目录
staticfiles/

# `pip` 和 `wheel` 构建的产物
/build/
/dist/
*.egg-info/