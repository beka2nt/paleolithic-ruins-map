# .env 文件

# --- 项目通用设置 ---
# Docker Compose 会使用这个名字作为容器和网络的前缀
PROJECT_NAME=ruinsproject

# --- Django Web 应用设置 ---
# 请生成一个新的、随机的强密钥。不要使用这个默认值！
# 可以使用命令: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-change-this-key-in-production

# 0 代表 False (生产/分发模式), 1 代表 True (开发模式)
DJANGO_DEBUG=1

# 允许访问的主机名，用空格分隔
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# 映射到您电脑（主机）的端口，已从8000修改为8888以避免冲突
DJANGO_PORT=8888

# --- PostgreSQL 数据库设置 ---
# 这些值将传递给数据库容器和 Django 应用
POSTGRES_DB=ruins_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456 # 请修改为您自己的强密码